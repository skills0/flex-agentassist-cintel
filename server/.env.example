# Twilio Account Credentials
# Find these at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=42...

# Twilio API Key & Secret
# Create at: https://console.twilio.com/us1/account/keys-credentials/api-keys
# Required for generating Voice tokens for browser clients
TWILIO_API_KEY=SK...
TWILIO_API_SECRET=mtu...

# Twilio Phone Number
# Format: +1234567890 (E.164 format with country code)
# Purchase at: https://console.twilio.com/us1/develop/phone-numbers/manage/search
# primary phone number for Flex inbound calls. Used to match agent interactions
TWILIO_FLEX_PHONE_NUMBER=+1xxxxxx1234

# OpenAI API Key (for AI customer simulation)
# Get your API key from: https://platform.openai.com/api-keys
# The AI customer is powered by OpenAI GPT-4
OPENAI_API_KEY=sk-projxxx

# Server Configuration
# For local development with ngrok: https://your-subdomain.ngrok.io
# IMPORTANT: Use the ngrok HTTPS URL here (will be converted to wss:// for WebSocket)
# Production: use your actual server URL
SERVER_URL=https://your-ngrok-url.ngrok.app
PORT=3001
